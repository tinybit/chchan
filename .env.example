# Postgres connection. On Vercel use the pooled Neon DATABASE_URL.
DATABASE_URL=postgres://localhost:5432/chchan

# Absolute base URL of the app (used for OAuth redirects).
APP_URL=http://localhost:3000

# Random 32+ byte hex strings. SESSION_SECRET signs nothing yet but is reserved;
# ANON_SECRET keys the author HMAC -- rotating it detaches all past posts from
# their authors permanently.
SESSION_SECRET=
ANON_SECRET=

# Google OAuth client (Google Cloud console). Leave empty to develop with
# DEV_FAKE_AUTH only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Site owner(s). Always log in as root (full access, assign admins) and are
# exempt from the ALLOWED_EMAIL_DOMAIN check. Comma-separated for multiple.
ROOT_EMAIL=

# Allowed Google Workspace domain for sign-in (e.g. yourcompany.com).
ALLOWED_EMAIL_DOMAIN=

# Dev only: enables /api/auth/dev-login?email=... (ignored in production builds).
DEV_FAKE_AUTH=1

# Where the local storage backend keeps uploaded images (dev only).
UPLOADS_DIR=./uploads

# Cloudflare R2 (production image storage). When all three R2_* credentials
# are set, uploads go to the bucket instead of local disk.
# R2_ENDPOINT looks like https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=chchan-images
