# Postgres connection. On Vercel use the pooled Neon DATABASE_URL.
DATABASE_URL=postgres://localhost:5432/chchan

# Absolute base URL of the app (used for OAuth redirects).
APP_URL=http://localhost:3000

# Random 32+ byte hex strings. SESSION_SECRET signs nothing yet but is reserved;
# ANON_SECRET keys the author HMAC -- rotating it detaches all past posts from
# their authors permanently.
SESSION_SECRET=
ANON_SECRET=

# Google OAuth client (Google Cloud console). Leave empty to develop with
# DEV_FAKE_AUTH only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The site owner. Always logs in as root (full access, assigns admins) and is
# the only account exempt from the ALLOWED_EMAIL_DOMAIN check.
ROOT_EMAIL=

# Allowed Google Workspace domain for sign-in.
ALLOWED_EMAIL_DOMAIN=clickhouse.com

# Dev only: enables /api/auth/dev-login?email=... (ignored in production builds).
DEV_FAKE_AUTH=1

# Where the local storage backend keeps uploaded images (dev only).
UPLOADS_DIR=./uploads
